# ============================================
# AI Configuration (Required for AI features)
# ============================================
GROQ_API_KEY=your_groq_api_key_here
# Alternative: GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# Maps Configuration (Required for tracking)
# ============================================
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
NEXT_PUBLIC_MAPTILER_API_KEY=your_maptiler_api_key

# ============================================
# Supabase Configuration (Required)
# ============================================
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ============================================
# Blockchain Configuration (Required)
# ============================================
NEXT_PUBLIC_CONTRACT_ADDRESS=your_deployed_contract_address
NEXT_PUBLIC_DEFAULT_CHAIN=sepolia

# Optional: Custom RPC URLs
# NEXT_PUBLIC_SEPOLIA_RPC_URL=https://rpc.sepolia.org
# NEXT_PUBLIC_POLYGON_AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# ============================================
# IPFS Configuration (Required for file uploads)
# ============================================
# Option 1: Pinata (Recommended)
NEXT_PUBLIC_PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_KEY=your_pinata_secret_key

# Option 2: Web3.Storage (Alternative)
# WEB3_STORAGE_TOKEN=your_web3_storage_token

# ============================================
# Email Notifications (SMTP) - Required
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=noreply@meditrustchain.com
SMTP_FROM_NAME=MediTrustChain

# ============================================
# Application URL (for email links)
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:9002

# ============================================
# Sentry Configuration (Error Monitoring)
# ============================================
# Get your DSN from https://sentry.io/
NEXT_PUBLIC_SENTRY_DSN=https://0155876f03a73c5e1e5d048614df9262@o4510608487022592.ingest.us.sentry.io/4510608490364928
SENTRY_ORG=your_sentry_org
SENTRY_PROJECT=your_sentry_project
SENTRY_AUTH_TOKEN=your_sentry_auth_token

# ============================================
# Application Configuration
# ============================================
NEXT_PUBLIC_APP_VERSION=1.0.0
NODE_ENV=development
